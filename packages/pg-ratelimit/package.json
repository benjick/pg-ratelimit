{
  "name": "pg-ratelimit",
  "version": "0.1.0",
  "description": "PostgreSQL-backed rate limiting for Node.js",
  "keywords": [
    "postgres",
    "postgresql",
    "rate-limit",
    "rate-limiting",
    "ratelimit",
    "throttle"
  ],
  "homepage": "https://benjick.js.org/pg-ratelimit",
  "bugs": {
    "url": "https://github.com/benjick/pg-ratelimit/issues"
  },
  "license": "MIT",
  "author": "Max Malm",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/benjick/pg-ratelimit.git",
    "directory": "packages/pg-ratelimit"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^10.0.0",
    "@types/pg": "^8.0.0",
    "pg": "^8.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "pg": "^8.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
